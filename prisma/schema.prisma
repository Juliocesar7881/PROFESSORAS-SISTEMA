generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plano {
  GRATUITO
  PRO
}

enum CategoriaObservacao {
  APRENDIZAGEM
  LINGUAGEM
  SOCIAL
  MOTOR
  CRIATIVIDADE
}

model User {
  id           String              @id @default(cuid())
  name         String?
  email        String?             @unique
  emailVerified DateTime?
  image        String?
  plano        Plano               @default(GRATUITO)
  stripeId     String?             @unique
  stripeSubId  String?
  deletedAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  accounts     Account[]
  sessions     Session[]
  turmas       Turma[]
  planejamentos Planejamento[]
  projetosSalvos ProjetoSalvo[]
  auditLogs    AuditLog[]

  @@index([createdAt])
}

model Turma {
  id          String         @id @default(cuid())
  nome        String
  faixaEtaria String
  ano         Int
  deletedAt   DateTime?
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  alunos       Aluno[]
  planejamentos Planejamento[]
  chamadas     Chamada[]

  @@index([userId])
  @@index([deletedAt])
}

model Aluno {
  id          String        @id @default(cuid())
  nome        String
  dataNasc    DateTime
  fotoKey     String?
  deletedAt   DateTime?
  turmaId     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  turma       Turma         @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  observacoes Observacao[]
  avaliacoes  Avaliacao[]
  presencas   Presenca[]

  @@index([turmaId])
  @@index([deletedAt])
}

model Observacao {
  id         String             @id @default(cuid())
  texto      String
  categoria  CategoriaObservacao
  alunoId    String
  createdAt  DateTime           @default(now())

  aluno      Aluno              @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  fotos      FotoObservacao[]

  @@index([alunoId, createdAt])
}

model FotoObservacao {
  id           String      @id @default(cuid())
  storageKey   String
  observacaoId String

  observacao   Observacao  @relation(fields: [observacaoId], references: [id], onDelete: Cascade)

  @@index([observacaoId])
}

model Avaliacao {
  id        String    @id @default(cuid())
  texto     String
  periodo   String
  alunoId   String
  createdAt DateTime  @default(now())

  aluno     Aluno     @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  @@index([alunoId, createdAt])
}

model Projeto {
  id            String         @id @default(cuid())
  titulo        String
  descricao     String
  categoria     String
  faixaEtaria   String
  duracao       String
  thumbnailKey  String?
  bnccObjetivos String[]
  premium       Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  atividades    Atividade[]
  salvosPor     ProjetoSalvo[]

  @@index([categoria])
  @@index([premium])
}

model Atividade {
  id          String      @id @default(cuid())
  titulo      String
  descricao   String
  categoria   String
  duracao     Int
  materiais   String[]
  bnccCodigos String[]
  projetoId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  projeto     Projeto?    @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  planejamentos PlanejamentoAtividade[]

  @@index([projetoId])
}

model Planejamento {
  id           String                  @id @default(cuid())
  semanaInicio DateTime
  semanaFim    DateTime
  userId       String
  turmaId      String
  shareToken   String?                 @unique
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  turma        Turma                   @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  atividades   PlanejamentoAtividade[]

  @@index([userId])
  @@index([turmaId])
  @@unique([userId, turmaId, semanaInicio])
}

model PlanejamentoAtividade {
  id             String       @id @default(cuid())
  diaSemana      Int
  horario        String
  atividadeId    String
  planejamentoId String

  atividade      Atividade    @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  planejamento   Planejamento @relation(fields: [planejamentoId], references: [id], onDelete: Cascade)

  @@index([planejamentoId])
  @@index([atividadeId])
}

model ProjetoSalvo {
  userId    String
  projetoId String
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projeto   Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  @@id([userId, projetoId])
  @@index([projetoId])
}

model Chamada {
  id        String     @id @default(cuid())
  data      DateTime   @db.Date
  turmaId   String
  createdAt DateTime   @default(now())

  turma     Turma      @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  presencas Presenca[]

  @@index([turmaId])
  @@unique([turmaId, data])
}

model Presenca {
  id           String   @id @default(cuid())
  presente     Boolean
  justificativa String?
  alunoId      String
  chamadaId    String

  aluno        Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  chamada      Chamada  @relation(fields: [chamadaId], references: [id], onDelete: Cascade)

  @@unique([alunoId, chamadaId])
  @@index([chamadaId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model StripeWebhookEvent {
  id          String   @id
  userId      String?
  payload     Json?
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
